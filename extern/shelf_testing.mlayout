named LAYOUT_NAME "example" # variable

# Create and select layout
create_layout "example"
summon_layout "example"

# config

set_cfg "camera_index" to "1"

# rest endpoints
set_cfg "rest_host" to "localhost"
set_cfg "rest_port" to "8000"

# load module

load_module "aruco" # ArUco marker detection
load_module "kiosk_events"
load_module "shelf_recognition"
load_module "rest_handler"
load_module "face_recognition"
load_module "audit_log"
load_module "pill_detector"

# face reg
set_cfg "face_detection_model" to "../extern/yunet.onnx"
set_cfg "face_recognition_model" to "../extern/sface.onnx"

# pill rec
set_cfg "pill_detector_model" to "../extern/astromed.onnx"
set_cfg "pill_images_dir" to "../extern/pill_images/"

#kiosk config
set_cfg "kiosk_event_ws_uri" to "ws://localhost:3000"
set_cfg "kiosk_event_ws_timeout_secs" to "30"

# ARUCO CODE GROUPS

create_codeset "box_tags"
summon_codeset "box_tags"
interpreter_set "box"

# Medication box markers
push_code 3
box_pretty_name 3 is "Medication Box A"

# ARUCO CODE GROUPS - SHELVES
# Codes in shelves act as polygons for spatial tracking

# SHELF 1 - Primary Medicine Storage
create_codeset "shelf1"
summon_codeset "shelf1"
interpreter_set "shelf"

# Four corner markers for shelf1
push_code 3
push_code 2
push_code 6
push_code 8

# LAYOUT BINDING

create_codeset "example"
summon_codeset "example"
interpreter_set "layout"

# FINAL BINDINGS
# Link medication boxes to shelves, and shelves to main layout

# Bind medication boxes to shelves
bind "box_tags" to "shelf1"

# Bind shelves to main layout
bind "shelf1" to "example"

# Crew Members
person "kerem" with_face "../extern/people/creamy.jpeg"
person "marco" with_face "../extern/people/marco.jpeg"
person "kerem" with_face "../extern/people/creamy_2.jpg"
person "nimul" with_face "../extern/people/nimul.png"
person "jimmy" with_face "../extern/people/jimmy_y.png"
person "kamil" with_face "../extern/people/kamil.png"
person "lakind" with_face "../extern/people/lakind.png"
person "abdullah" with_face "../extern/people/abdullah.png"