named LAYOUT_NAME "example" # variable

# NASA HUNCH ISS MEDICAL TRACKER - CONFIG FILE
# this cool thing consists of ArUco tracking + Face Recognition + Medicine AI

# Create and select layout
create_layout "example"
summon_layout "example"

# config

set_cfg "camera_index" to "1"

# load module

#load_module "aruco" # ArUco marker detection
#load_module "face_recognition" # Face recognition for user identification
#load_module "medicine_ai" # AI-powered medicine tracking
load_module "kiosk_events"

# facial config

# Model paths
set_cfg "face_detection_model" to "../extern/yunet.onnx"
set_cfg "face_recognition_model" to "../extern/sface.onnx"

#kiosk config
set_cfg "kiosk_event_ws_uri" to "ws://localhost:8765"
set_cfg "kiosk_event_ws_timeout_secs" to "30"

# CREW MEMBER REGISTRATION

person "kerem" with_face "../extern/people/creamy.jpeg"
person "marco" with_face "../extern/people/marco.jpeg"
person "kerem" with_face "../extern/people/creamy_2.jpg"
person "nimul" with_face "../extern/people/nimul.png"
person "drgold" with_face "../extern/people/drgold.png"
person "jimmy" with_face "../extern/people/jimmy_y.png"
person "kamil" with_face "../extern/people/kamil.png"
person "lakind" with_face "../extern/people/lakind.png"
person "abdullah" with_face "../extern/people/abdullah.png"

# MEDICINE AI CONFIGURATION

# AI/ML Parameters
set_cfg "medicine_ai_smoothing_alpha" to "0.3"        # Exponential smoothing factor
set_cfg "medicine_ai_trend_beta" to "0.1"             # Trend component factor
set_cfg "medicine_ai_min_samples" to "10"             # Minimum samples for training
set_cfg "medicine_ai_training_interval" to "24"       # Hours between retraining

# Storage Configuration
set_cfg "medicine_ai_storage_path" to "./medicine_data/"

# MEDICATION BOX TO MARKER MAPPINGS
# Maps ArUco marker IDs to medications and users

# Ibuprofen boxes (marker IDs 110, 230)
set_cfg "marker_110_medication" to "MED001" # Ibuprofen 200mg
set_cfg "marker_110_user" to "creamy"
set_cfg "marker_230_medication" to "MED001" # Ibuprofen 200mg
set_cfg "marker_230_user" to "marco"

# Aspirin boxes (marker IDs 260, 360)
set_cfg "marker_260_medication" to "MED002" # Aspirin 325mg
set_cfg "marker_260_user" to "creamy"
set_cfg "marker_360_medication" to "MED002" # Aspirin 325mg
set_cfg "marker_360_user" to "marco"

# Acetaminophen boxes (marker IDs 112, 232)
set_cfg "marker_112_medication" to "MED003" # Acetaminophen 500mg
set_cfg "marker_112_user" to "creamy"
set_cfg "marker_232_medication" to "MED003" # Acetaminophen 500mg
set_cfg "marker_232_user" to "marco"

# Diphenhydramine boxes (marker IDs 262, 332)
set_cfg "marker_262_medication" to "MED004" # Diphenhydramine 25mg
set_cfg "marker_262_user" to "creamy"
set_cfg "marker_332_medication" to "MED004" # Diphenhydramine 25mg
set_cfg "marker_332_user" to "marco"

# ARUCO CODE GROUPS

create_codeset "box_tags"
summon_codeset "box_tags"
interpreter_set "box"

# Medication box markers
push_code 110
push_code 230

# ARUCO CODE GROUPS - SHELVES
# Each shelf has 4 corner markers for spatial tracking

# SHELF 1 - Primary Medicine Storage
create_codeset "shelf1"
summon_codeset "shelf1"
interpreter_set "shelf"

# Four corner markers for shelf1
push_code 110
push_code 230
push_code 260
push_code 360

# SHELF 2 - Secondary Medicine Storage
create_codeset "shelf2"
summon_codeset "shelf2"
interpreter_set "shelf"

# Four corner markers for shelf2
push_code 112
push_code 232
push_code 262
push_code 332

# LAYOUT BINDING

create_codeset "example"
summon_codeset "example"
interpreter_set "layout"

# FINAL BINDINGS
# Link medication boxes to shelves, and shelves to main layout

# Bind medication boxes to shelves
bind "box_tags" to "shelf1"
bind "box_tags" to "shelf2"

# Bind shelves to main layout
bind "shelf1" to "example"
bind "shelf2" to "example"

# resup config
# settings for ISS resupply report generation

set_cfg "resupply_mission_duration" to "180"      # Days
set_cfg "resupply_safety_margin" to "1.2"         # 20% extra
set_cfg "resupply_auto_generate" to "false"       # Manual generation

# logger config

set_cfg "log_level" to "info"                     # debug, info, warning, error
set_cfg "log_adherence_events" to "true"          # Log all medication events
set_cfg "log_predictions" to "false"              # Don't spam with predictions

# MORE ALERT THRESHOLDS

set_cfg "alert_low_stock_threshold" to "10"       # Alert when < 10 doses remain
set_cfg "alert_adherence_threshold" to "0.85"     # Alert when adherence < 85%
set_cfg "alert_temperature_threshold" to "80"     # Alert when GPU > 80°C